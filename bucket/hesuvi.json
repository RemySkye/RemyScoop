{
    "version": "2.0.0.1",
    "description": "Headphone Surround Virtualizations for Equalizer APO",
    "homepage": "https://sourceforge.net/projects/hesuvi/",
    "url": "https://downloads.sourceforge.net/project/hesuvi/HeSuVi_2.0.0.1.exe#/HeSuVi.7z",
    "hash": "sha1:c5f47896b7bfb311ae2e0df6b2d7f5f1df743e18",
    "post_install": [
        "$apoPath = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\EqualizerAPO' -Name 'ConfigPath' -ErrorAction SilentlyContinue).ConfigPath",
        "if ($null -eq $apoPath -or -not (Test-Path $apoPath)) {",
        "    Write-Host 'Warning: Equalizer APO was not found on this system!' -ForegroundColor Yellow",
        "    Write-Host 'Install Equalizer APO first, then reinstall HeSuVi.' -ForegroundColor Yellow",
        "} else {",
        "    Write-Host 'Linking HeSuVi inside Equalizer APO config directory...' -ForegroundColor Green",
        "    if (Test-Path \"$apoPath\\HeSuVi\") { Remove-Item \"$apoPath\\HeSuVi\" -Force -Recurse }",
        "    New-Item -ItemType Junction -Path \"$apoPath\\HeSuVi\" -Target \"$dir\\HeSuVi\" -Force | Out-Null",
        "}"
    ],
    "pre_uninstall": [
        "$apoPath = (Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\EqualizerAPO' -Name 'ConfigPath' -ErrorAction SilentlyContinue).ConfigPath",
        "if ($apoPath -and (Test-Path \"$apoPath\\HeSuVi\")) {",
        "    Remove-Item \"$apoPath\\HeSuVi\" -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "shortcuts": [
        [
            "HeSuVi\\HeSuVi.exe",
            "HeSuVi"
        ]
    ],
    "checkver": {
        "url": "https://sourceforge.net/projects/hesuvi/rss",
        "regex": "HeSuVi_([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "url": "https://downloads.sourceforge.net/project/hesuvi/HeSuVi_$version.exe#/HeSuVi.7z"
    }
}
